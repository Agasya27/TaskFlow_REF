# Copy to .env and fill in values from Firebase Console → Project Settings → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In — from Firebase / Google Cloud Console
# Required for Google button (used in GoogleSignin.configure on Android)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Required on iOS only
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Standalone Android APK: SHA-1 from `npx eas credentials -p android` (apk profile).
# Also add google-services.json (download from Firebase → Android app settings).
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
