{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@screens/*": ["./src/screens/*"],
      "@store/*": ["./src/store/*"],
      "@services/*": ["./src/services/*"],
      "@utils/*": ["./src/utils/*"],
      "@theme/*": ["./src/theme/*"],
      "@assets/*": ["./assets/*"],
      "@navigation/*": ["./src/navigation/*"],
      "@config/*": ["./src/config/*"],
      "@hooks/*": ["./src/hooks/*"]
    }
  }
}
